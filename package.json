{
  "name": "coborouter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/demo/server.ts",
    "demo": "tsx src/demo/cli.ts approved",
    "demo:blocked": "tsx src/demo/cli.ts blocked",
    "demo:approved": "tsx src/demo/cli.ts approved",
    "demo:budget-declined": "tsx src/demo/cli.ts budget_declined",
    "demo:local": "tsx src/demo/cli.ts local",
    "demo:zai-flash": "tsx src/demo/cli.ts simple_zai",
    "demo:provider-denied": "tsx src/demo/cli.ts provider_not_allowlisted",
    "demo:human-approval": "tsx src/demo/cli.ts human_approval",
    "demo:settlement-failure": "tsx src/demo/cli.ts settlement_failure",
    "e2e:agent": "tsx src/demo/e2eAgentClient.ts",
    "check": "tsc --noEmit",
    "smoke": "npm run demo:blocked && npm run demo:approved",
    "ci:local": "npm run check && npm run secret:scan && npm run smoke && npm run e2e:agent && npm run verify:receipt -- receipts/coborouter_demo_approved_001.json && npm run verify:receipt -- receipts/coborouter_demo_blocked_001.json",
    "verify:receipt": "tsx src/demo/verifyReceipt.ts",
    "check:live": "tsx src/demo/checkLiveGates.ts",
    "check:live:strict": "tsx src/demo/checkLiveGates.ts --strict",
    "capture:screenshots": "tsx src/demo/captureScreenshots.ts",
    "secret:scan": "tsx src/demo/secretScan.ts",
    "product:verify": "npm run ci:local"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "optionalDependencies": {
    "@cobo/agentic-wallet": "^0.1.7"
  }
}
